{
  "functions": {
    "api/index.py": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/webhook", "dest": "/api/index.py" },
    { "src": "/dashboard", "dest": "/api/index.py" },
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/", "dest": "/api/index.py" }
  ]
}
