{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "runtime": "python3.11" }
    }
  ],
  "routes": [
    { "src": "/webhook", "dest": "api/index.py", "methods": ["POST"] },
    { "src": "/dashboard", "dest": "api/index.py" },
    { "src": "/health", "dest": "api/index.py" },
    { "src": "/favicon.ico", "dest": "api/index.py" },
    { "src": "/favicon.png", "dest": "api/index.py" },
    { "src": "/(.*)", "dest": "api/index.py" }
  ],
  "env": {
    "FLASK_ENV": "production",
    "PYTHONUNBUFFERED": "1"
  }
}
