{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/", "dest": "api/index.py" }, 
    { "src": "/api/index", "dest": "api/index.py" },
    { "src": "/api/set_webhook", "dest": "api/index.py" },
    { "src": "/api/chat", "dest": "api/index.py" },
    { "src": "/dashboard", "dest": "/templates/dashboard.html" }
  ]
}
