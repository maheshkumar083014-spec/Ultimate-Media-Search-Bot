{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/webhook",
      "dest": "api/index.py",
      "methods": ["POST"]
    },
    {
      "src": "/dashboard",
      "dest": "api/index.py"
    },
    {
      "src": "/welcome",
      "dest": "api/index.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/index.py",
      "methods": ["GET", "POST", "OPTIONS"],
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Headers": "Content-Type"
      }
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "BOT_TOKEN": "8701635891:AAFYh5tUdnHknFkXJhu06-K1QevJMz3P2sw",
    "FIREBASE_DATABASE_URL": "https://ultimatemediasearch-default-rtdb.asia-southeast1.firebasedatabase.app/"
  }
}
