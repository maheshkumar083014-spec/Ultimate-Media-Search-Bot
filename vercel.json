{
  "version": 2,
  "builds": [
    {
      "src": "index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/index",
      "methods": ["POST", "GET"],
      "dest": "index.py"
    },
    {
      "src": "/webhook",
      "methods": ["POST", "GET"],
      "dest": "index.py"
    },
    {
      "src": "/(.*)",
      "dest": "index.py"
    }
  ],
  "env": {
    "BOT_TOKEN": "@bot_token",
    "DEEPSEEK_API_KEY": "@deepseek_key",
    "FIREBASE_PRIVATE_KEY": "@fb_private_key",
    "FIREBASE_CLIENT_EMAIL": "@fb_client_email",
    "UPI_ID": "8543083014@mbk",
    "AD_LINK": "@ad_link"
  }
}
